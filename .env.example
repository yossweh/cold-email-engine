# 0xChapo — AI Cold Email Engine
# Environment Variables

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM_NAME=Your Name
SMTP_FROM_EMAIL=your@email.com

# Dashboard
DASHBOARD_PORT=5000
DASHBOARD_SECRET=change-this-to-random-string

# Rate Limiting
MAX_EMAILS_PER_HOUR=30
DELAY_BETWEEN_EMAILS_SEC=60

# LemonSqueezy Payments (International)
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_PRO=variant-id-for-pro
LEMONSQUEEZY_VARIANT_ENTERPRISE=variant-id-for-enterprise
LEMONSQUEEZY_REDIRECT_URL=http://localhost:5000/dashboard

# Midtrans Payments (Indonesia)
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v2/vtweb
MIDTRANS_REDIRECT_URL=http://localhost:5000/dashboard
MIDTRANS_ENABLED_PAYMENTS=qris,gopay,ovo,shopeepay,bca_va,bni_va,bri_va,credit_card
